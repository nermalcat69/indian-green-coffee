---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig } from '../config/site';

const title = 'About Indian Green Coffee | Gray Cup Enterprises';
const description =
	'Indian Green Coffee is an origin guide published by Gray Cup Enterprises, exporters of Indian green coffee since 2019.';

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'AboutPage',
		name: title,
		description,
		url: `${siteConfig.siteUrl}/about`,
	},
];
---

<Layout title={title} description={description} schema={schema}>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page">
		<SiteHeader />

		<main id="main-content">
			<section class="hero">
				<p class="eyebrow">About</p>
				<h1 class="display-title">A guide, not a storefront</h1>
				<p class="hero-text">
					Indian Green Coffee is a reference site about where India's green coffee comes from —
					published by Gray Cup Enterprises, exporters of Indian green coffee since 2019.
				</p>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Why this exists</p>
				</div>
				<div class="story-block">
					<p>
						Most green coffee buyers researching India end up comparing a handful of well-known
						districts without much context on how they differ — elevation, varietal, processing
						tradition, or the kind of farms actually growing the coffee. This site exists to fill
						that gap: plain information about Koraput, Halflong, the Chirang–Tirap Robusta belt,
						and Chikmagalur–Bababudangiri, kept up to date as our own sourcing relationships in
						each region evolve.
					</p>
				</div>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Gray Cup Enterprises</p>
				</div>
				<div class="story-block">
					<p>
						Gray Cup sources and exports Indian green coffee, chai, and CTC tea to roasters,
						importers, and distributors worldwide. We work directly with tribal cooperatives in
						Koraput, smallholder farms in Assam and Arunachal Pradesh, and estates in Karnataka —
						handling grading, export documentation, and logistics in-house.
					</p>
					<p>
						For current pricing, samples, and country-specific shipping, our wholesale ordering
						site is <a href="https://bulkgreencoffee.com" target="_blank" rel="noopener noreferrer">bulkgreencoffee.com</a>.
						This site stays focused on origin information rather than transactions.
					</p>
				</div>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Contact</p>
				</div>
				<div class="story-block">
					<p>
						Questions about a specific origin, or want something covered that isn't here? Email
						<a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
					</p>
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.eyebrow,
	.section-kicker {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		line-height: 1.4;
		text-transform: uppercase;
		margin: 0;
		color: var(--muted-foreground);
	}

	.hero {
		padding: 6rem 0 4rem;
		max-width: 44rem;
	}

	.hero-text {
		font-size: 1.15rem;
		line-height: 1.65;
		margin: 1.5rem 0 0;
	}

	.editorial-section {
		display: grid;
		grid-template-columns: 16rem minmax(0, 1fr);
		gap: 2rem;
		padding: 2.5rem 0;
		border-top: 1px solid var(--border);
	}

	.section-rail {
		align-self: start;
	}

	.story-block {
		display: grid;
		gap: 1rem;
		max-width: 46rem;
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.story-block a {
		color: var(--accent-link);
	}

	@media (max-width: 1100px) {
		.editorial-section {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.hero {
			padding: 4rem 0 3rem;
		}

		.hero-text {
			font-size: 1.05rem;
		}
	}
</style>
