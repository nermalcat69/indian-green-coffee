---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import figmaLogo from '../assets/logos/figma.svg';
import framerLogo from '../assets/logos/framer.svg';
import shopifyLogo from '../assets/logos/shopify.svg';
import webflowLogo from '../assets/logos/webflow.svg';

const tools = [
	{ name: 'Figma', logo: figmaLogo, tone: 'light' },
	{ name: 'Framer', logo: framerLogo, tone: 'dark' },
	{ name: 'Shopify', logo: shopifyLogo, tone: 'light' },
	{ name: 'Webflow', logo: webflowLogo, tone: 'light' },
];
---

<Layout
	title="Resume | Astro Theme for UI/UX Designer Portfolios"
	description="Resume page example from the Maria Astro theme for UI/UX designer portfolios, showcasing experience, capabilities, and tools."
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page">
		<SiteHeader />

		<main id="main-content">
			<section class="hero">
				<p class="eyebrow">Resume</p>
				<h1 class="display-title">10+ years shaping digital products through UX, UI, and systems thinking.</h1>
				<div class="hero-subgrid">
					<p class="hero-text">
						My work has focused on product clarity: helping teams bring structure to messy
						workflows, overloaded interfaces, and growing systems that need to scale without
						becoming harder to use.
					</p>
				</div>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Snapshot</p>
				</div>
				<div class="story-block">
					<p><strong>Location:</strong> Europe</p>
					<p><strong>Focus:</strong> UX Design / Product Design</p>
					<p><strong>Specialties:</strong> Dashboards, workflows, design systems</p>
					<p><strong>Contact:</strong> <a href="mailto:hello@maria.com">hello@maria.com</a></p>
				</div>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Experience</p>
				</div>
				<div class="story-block">
					<p>
						<strong>Lead UX Designer</strong><br />
						Independent / Consulting, 2021 - Present
					</p>
					<p>
						Leading interface design, product thinking, and design systems work across SaaS and
						service platforms.
					</p>
					<p>
						<strong>Senior Product Designer</strong><br />
						Digital Product Studio, 2017 - 2021
					</p>
					<p>
						Designed workflows, dashboards, and multi-platform product experiences for startup
						and enterprise clients.
					</p>
					<p>
						<strong>UI/UX Designer</strong><br />
						In-house Product Teams, 2014 - 2017
					</p>
					<p>
						Built core interface patterns, user flows, and production-ready visual systems for
						web and mobile products.
					</p>
				</div>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Capabilities</p>
				</div>
				<div class="story-block">
					<p>
						<strong>Product Strategy:</strong> framing problems, prioritizing experience
						decisions, and aligning product goals with user value.
					</p>
					<p>
						<strong>UI Systems:</strong> building coherent interface languages that scale across
						flows, features, and implementation teams.
					</p>
					<p>
						<strong>Execution:</strong> taking concepts through wireframes, high-fidelity UI,
						refinement, and developer-ready handoff.
					</p>
				</div>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Tools</p>
				</div>
				<div class="tools-grid">
					{
						tools.map((tool) => (
							<div class="tool-card">
								<div class:list={['tool-mark', tool.tone === 'dark' && 'tool-mark-dark']} aria-hidden="true">
									<Image class="tool-logo" src={tool.logo} alt="" loading="lazy" />
								</div>
								<p class="tool-name">{tool.name}</p>
							</div>
						))
					}
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.eyebrow,
	.section-kicker {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.hero {
		padding: 6rem 0 4rem;
	}

	.eyebrow,
	.section-kicker {
		margin: 0;
		color: var(--muted-foreground);
		font-style: normal;
	}

	.hero-subgrid {
		display: grid;
		grid-template-columns: 1fr;
		margin-top: 1.75rem;
	}

	.hero-text,
	.story-block p {
		font-size: 1.08rem;
		line-height: 1.7;
		margin: 0;
	}

	.editorial-section {
		display: grid;
		grid-template-columns: 16rem minmax(0, 1fr);
		gap: 2rem;
		padding: 2.5rem 0;
		border-top: 1px solid var(--border);
	}

	.section-rail {
		align-self: start;
	}

	.story-block {
		display: grid;
		gap: 1rem;
		max-width: 52rem;
	}

	.story-block strong {
		color: var(--foreground);
	}

	.tools-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		max-width: 44rem;
	}

	.tool-card {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		padding: 1rem 1.05rem;
		border: 1px solid var(--border);
		border-radius: 1.15rem;
		background: var(--card);
	}

	.tool-mark {
		width: 3rem;
		height: 3rem;
		flex: 0 0 3rem;
		display: grid;
		place-items: center;
		border-radius: 0.9rem;
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--muted) 90%, var(--card) 10%) 0%,
			color-mix(in srgb, var(--border) 55%, var(--card) 45%) 100%
		);
		border: 1px solid color-mix(in srgb, var(--border) 88%, var(--background) 12%);
		font-size: 0.95rem;
		font-weight: 800;
		letter-spacing: -0.04em;
		color: var(--foreground);
	}

	.tool-mark-dark {
		background: #111111;
		border-color: #111111;
	}

	.tool-logo {
		width: 1.55rem;
		height: 1.55rem;
		display: block;
		object-fit: contain;
	}

	.tool-name {
		margin: 0;
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	@media (max-width: 980px) {
		.hero-subgrid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.hero {
			padding: 4rem 0 3rem;
		}

		.editorial-section {
			grid-template-columns: 1fr;
		}

		.hero-text,
		.story-block p {
			font-size: 1.05rem;
		}

		.tools-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
