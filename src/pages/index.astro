---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { origins } from '../data/origins';
import { siteConfig } from '../config/site';

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: siteConfig.name,
		url: siteConfig.siteUrl,
		description: siteConfig.description,
		inLanguage: siteConfig.locale,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		'@id': `${siteConfig.siteUrl}/#organization`,
		name: siteConfig.authorName,
		alternateName: 'Indian Green Coffee',
		description: siteConfig.authorRole,
		url: siteConfig.siteUrl,
		email: siteConfig.email,
		sameAs: siteConfig.socialLinks.map((link) => link.href),
		address: {
			'@type': 'PostalAddress',
			addressCountry: 'IN',
		},
	},
];
---

<Layout
	title={siteConfig.title}
	description={siteConfig.description}
	schema={schema}
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page">
		<SiteHeader />

		<main id="main-content">
			<section class="hero" id="top">
				<div class="hero-copy">
					<h1 class="display-title">A field guide to India's green coffee origins.</h1>
					<p class="hero-text">
						India grows more coffee than most buyers realise — shade-grown Arabica from tribal
						farms in Odisha, young specialty plantings in Assam's hill districts, and the
						century-old estates around Chikmagalur where Indian coffee began. This is a guide to
						where it comes from, how it's processed, and what to expect in the cup.
					</p>
					<p class="hero-note">
						Looking to buy? Visit <a href="https://bulkgreencoffee.com" target="_blank" rel="noopener noreferrer">bulkgreencoffee.com</a>
						for wholesale pricing, samples, and country-specific shipping — or see our
						<a href="/wholesale">wholesale sourcing overview</a>.
					</p>
				</div>
			</section>

			<section class="origins" id="origins" aria-labelledby="origins-heading">
				<h2 id="origins-heading" class="section-title">Four origins, four very different cups</h2>
				<div class="origins-grid">
					{
						origins.map((origin) => (
							<a class="origin-link" href={`/origins/${origin.slug}`}>
								<article class={`accent-card ${origin.accent}`}>
									<p class="origin-region">{origin.state} — {origin.region}</p>
									<h3 class="origin-title">{origin.name}</h3>
									<p class="origin-summary">{origin.summary}</p>
									<p class="origin-meta">{origin.elevation} · {origin.varieties}</p>
								</article>
							</a>
						))
					}
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.hero {
		padding: 7rem 0 5rem;
	}

	.hero-copy {
		width: 100%;
		max-width: 100%;
	}

	.hero-text {
		max-width: 42rem;
		margin: 1.5rem 0 0;
		font-size: 1.2rem;
		line-height: 1.55;
	}

	.hero-note {
		max-width: 42rem;
		margin: 1.25rem 0 0;
		color: var(--muted-foreground);
		font-size: 1.05rem;
		line-height: 1.6;
	}

	.hero-note a {
		color: var(--accent-link);
	}

	.section-title {
		margin: 0 0 2rem;
		font-size: clamp(1.6rem, 2.4vw, 2.1rem);
		font-weight: 800;
		letter-spacing: -0.04em;
	}

	.origins {
		padding: 2rem 0 4rem;
		border-top: 1px solid var(--border);
	}

	.origins-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.75rem;
	}

	.origin-link {
		display: block;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}

	.origin-region {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		opacity: 0.72;
	}

	.origin-title {
		margin: 0.6rem 0 0;
		font-size: clamp(1.4rem, 1.8vw, 1.7rem);
		font-weight: 800;
		letter-spacing: -0.03em;
	}

	.origin-summary {
		margin: 0.85rem 0 0;
		font-size: 1rem;
		line-height: 1.55;
	}

	.origin-meta {
		margin: 1rem 0 0;
		font-size: 0.88rem;
		font-weight: 600;
		opacity: 0.72;
	}

	@media (max-width: 900px) {
		.origins-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.hero {
			padding: 4rem 0 3rem;
		}

		.hero-text {
			font-size: 1.05rem;
		}
	}
</style>
