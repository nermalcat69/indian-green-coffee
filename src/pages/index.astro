---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { projects } from '../data/projects';
---

<Layout
	title="Maria | Astro Theme for UI/UX Designer Portfolios"
	description="An Astro theme for UI/UX designer portfolios with case study pages, a polished homepage, and modern product design presentation."
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page">
		<SiteHeader />

		<main id="main-content">
			<section class="hero" id="top">
				<div class="hero-copy">
					<h1 class="display-title">Hi, I'm Maria. I design digital products that actually make sense.</h1>
					<p class="hero-text">
						Ten-plus years helping teams turn messy problems into clear, useful experiences.
						Corporations, startups, scrappy independents: if there's a user confused
						somewhere, I want to fix that.
					</p>
					<p class="hero-note" id="about">
						I work best in the messy middle - where requirements are fuzzy, stakes are real,
						and good design actually matters.
					</p>
				</div>
			</section>

			<section class="projects" id="work">
				<div class="projects-grid">
					{
						projects.map((project, index) => (
							<a class="project-link" href={project.href}>
								<article class={`project-card ${project.background}`}>
									<div class="project-header">
										<p class="project-name">{project.name}</p>
									</div>
									<h2 class="project-title">{project.title}</h2>

									<div class={`project-visual ${project.variant}`}>
										<Image
											class={project.imageClass}
											src={project.image}
											alt={project.alt}
											loading={index < 2 ? 'eager' : 'lazy'}
											decoding="async"
											widths={[480, 720, 960]}
											sizes="(max-width: 980px) 100vw, 50vw"
										/>
									</div>
								</article>
							</a>
						))
					}
				</div>
			</section>

		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.eyebrow,
	.project-name {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.hero {
		padding: 7rem 0 6.5rem;
	}

	.hero-copy {
		width: 100%;
		max-width: 100%;
	}

	.eyebrow,
	.project-name {
		margin: 0;
		color: var(--muted-foreground);
		font-style: normal;
	}

	.project-card .project-name {
		color: rgba(23, 23, 23, 0.72);
	}

	.project-card h2 {
		color: #171717;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		font-weight: 800;
		letter-spacing: -0.05em;
		color: var(--foreground);
	}

	.hero-text,
	.hero-note,
	blockquote,
	.footer-note p,
	.footer-note a {
		font-size: 1.2rem;
		line-height: 1.55;
	}

	.hero-text {
		max-width: 38rem;
		margin: 1.5rem 0 0;
	}

	.hero-note {
		max-width: 40rem;
		margin: 1rem 0 0;
		color: var(--muted-foreground);
		font-style: italic;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
	}

	.project-link {
		display: block;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}

	.project-link:hover,
	.project-link:focus-visible,
	.project-link:visited,
	.project-link:active {
		color: inherit;
		text-decoration: none;
	}

	.project-card {
		display: grid;
		grid-template-rows: auto minmax(4.4rem, auto) 1fr;
		gap: 1.35rem;
		height: 100%;
		padding: 1.5rem;
		border-radius: 1.35rem;
		overflow: hidden;
		transition:
			transform 140ms ease,
			box-shadow 140ms ease;
	}

	.project-link:hover .project-card,
	.project-link:focus-visible .project-card {
		transform: translateY(-4px);
		box-shadow: var(--shadow-soft);
	}

	.project-link:focus-visible {
		outline-offset: 6px;
	}

	.project-card.lime {
		background: #dbff63;
	}

	.project-card.cyan {
		background: #91e6ee;
	}

	.project-card.lavender {
		background: #c5baf9;
	}

	.project-card.mint {
		background: #78f1cf;
	}

	.project-header {
		display: flex;
		align-items: center;
		justify-content: flex-start;
	}

	h2 {
		font-size: clamp(1.85rem, 2.4vw, 2.35rem);
		line-height: 1.04;
	}

	.project-title {
		max-width: none;
		width: 100%;
		font-size: clamp(1.45rem, 1.75vw, 1.9rem);
		line-height: 1.16;
		letter-spacing: -0.04em;
		text-wrap: pretty;
	}

	.project-card.cyan .project-title,
	.project-card.mint .project-title {
		font-size: clamp(1.35rem, 1.62vw, 1.74rem);
	}

	.project-visual {
		position: relative;
		height: 17rem;
		min-height: 0;
		display: grid;
		align-items: end;
		justify-items: center;
		overflow: hidden;
	}

	.project-preview-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		border-radius: 1rem;
		box-shadow: var(--shadow-medium);
	}

	.project-visual.split {
		grid-template-columns: 8rem 1fr;
		gap: 1rem;
		align-items: end;
	}

	.project-visual.split .project-preview-image {
		grid-column: 1 / -1;
	}

	.ui-window,
	.ui-phone,
	.ui-board {
		background: var(--card);
		border: 1.5px solid color-mix(in srgb, var(--foreground) 10%, transparent);
		box-shadow: var(--shadow-medium);
	}

	.ui-window {
		width: 100%;
		height: 13.75rem;
		border-radius: 0.95rem;
		overflow: hidden;
	}

	.ui-window.compact {
		height: 13rem;
	}

	.ui-topbar {
		height: 1rem;
		background: color-mix(in srgb, var(--foreground) 86%, #2f3640 14%);
	}

	.ui-window-body {
		display: grid;
		grid-template-columns: 5rem 1fr;
		height: calc(100% - 1rem);
	}

	.ui-column {
		background: color-mix(in srgb, var(--card) 72%, var(--background) 28%);
		border-right: 1px solid color-mix(in srgb, var(--border) 88%, var(--background) 12%);
	}

	.ui-content,
	.ui-content.tight {
		padding: 0.9rem;
		display: grid;
		align-content: start;
		gap: 0.65rem;
	}

	.ui-line,
	.ui-panel,
	.ui-phone-card,
	.ui-photo,
	.ui-board-card,
	.ui-table-row,
	.ui-search {
		border-radius: 0.7rem;
	}

	.ui-line {
		height: 0.8rem;
		background: color-mix(in srgb, var(--border) 85%, var(--background) 15%);
	}

	.ui-line.short {
		width: 56%;
	}

	.ui-panel.large {
		height: 4.8rem;
		background: color-mix(in srgb, var(--muted) 60%, var(--card) 40%);
		border: 1px solid color-mix(in srgb, var(--border) 90%, var(--background) 10%);
	}

	.ui-panel-row {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.7rem;
	}

	.ui-panel {
		height: 3.4rem;
		background: color-mix(in srgb, var(--muted) 72%, var(--card) 28%);
		border: 1px solid color-mix(in srgb, var(--border) 90%, var(--background) 10%);
	}

	.ui-phone {
		width: 7.25rem;
		height: 13rem;
		padding: 0.65rem 0.55rem;
		border-radius: 1.2rem;
		display: grid;
		align-content: start;
		gap: 0.45rem;
	}

	.ui-phone.tall {
		width: 7.5rem;
		height: 14.3rem;
	}

	.ui-phone-notch {
		width: 2.4rem;
		height: 0.45rem;
		margin: 0 auto 0.2rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--foreground) 92%, #232323 8%);
	}

	.ui-phone-line {
		height: 0.68rem;
		background: color-mix(in srgb, var(--border) 76%, var(--background) 24%);
	}

	.ui-phone-line.short {
		width: 60%;
	}

	.ui-phone-card {
		height: 2.35rem;
		background: color-mix(in srgb, var(--muted) 52%, var(--card) 48%);
		border: 1px solid color-mix(in srgb, var(--border) 88%, var(--background) 12%);
	}

	.ui-phone-card.slim {
		height: 1.5rem;
	}

	.ui-photo {
		height: 4.6rem;
		background: linear-gradient(135deg, #dce7f5 0%, #f5dcc9 100%);
		border: 1px solid color-mix(in srgb, var(--border) 88%, var(--background) 12%);
	}

	.phones {
		display: flex;
		gap: 0.8rem;
		align-items: end;
		justify-content: center;
	}

	.ui-table-row {
		height: 1.6rem;
		background: color-mix(in srgb, var(--muted) 56%, var(--card) 44%);
		border: 1px solid color-mix(in srgb, var(--border) 88%, var(--background) 12%);
	}

	.ui-board {
		width: 100%;
		height: 14.5rem;
		padding: 0.9rem;
		border-radius: 1rem;
		display: grid;
		gap: 0.8rem;
	}

	.ui-board-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 0.8rem;
	}

	.ui-search {
		height: 1.45rem;
		flex: 1;
		background: color-mix(in srgb, var(--muted) 56%, var(--card) 44%);
		border: 1px solid color-mix(in srgb, var(--border) 88%, var(--background) 12%);
	}

	.ui-avatar {
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 50%;
		background: color-mix(in srgb, var(--border) 84%, var(--background) 16%);
	}

	.ui-board-grid {
		display: grid;
		grid-template-columns: 1.2fr 1fr 1fr;
		gap: 0.7rem;
		height: 100%;
	}

	.ui-board-card {
		min-height: 4rem;
		background: color-mix(in srgb, var(--muted) 52%, var(--card) 48%);
		border: 1px solid color-mix(in srgb, var(--border) 88%, var(--background) 12%);
	}

	.ui-board-card.feature {
		grid-row: span 2;
	}

	@media (max-width: 980px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.hero {
			padding: 4rem 0 4.5rem;
		}

		.hero-text,
		.hero-note {
			font-size: 1.05rem;
		}

		.project-card {
			grid-template-rows: auto auto 1fr;
			padding: 1.25rem;
			border-radius: 1.15rem;
		}

		.project-title {
			min-height: auto;
		}

		.project-visual {
			height: auto;
			overflow: visible;
			align-items: start;
		}

		.project-visual.split {
			grid-template-columns: 6.5rem 1fr;
		}

		.project-preview-image {
			height: auto;
			object-fit: initial;
			object-position: initial;
		}

		.ui-phone,
		.ui-phone.tall {
			width: 6.3rem;
			height: 12.3rem;
		}

		.desktop-hide-small {
			display: none;
		}
	}
</style>
