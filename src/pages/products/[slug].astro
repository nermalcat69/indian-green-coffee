---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { products, getProductBySlug } from '../../data/products';
import { getOriginBySlug } from '../../data/origins';
import { siteConfig } from '../../config/site';

export function getStaticPaths() {
	return products.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
// getStaticPaths above only ever generates params for known products, so this is always defined.
const product = getProductBySlug(slug as string)!;
const origin = getOriginBySlug(product.originSlug)!;

const pageUrl = `${siteConfig.siteUrl}/products/${product.slug}`;
const title = `${product.name} | Indian Green Coffee`;
const description = `${product.summary} ${product.process}, ${product.varietal}. ₹${product.priceRange.min}-${product.priceRange.max}${product.priceRange.unit} FOB India. MOQ ${product.minimumOrder.quantity}${product.minimumOrder.unit}.`;

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.siteUrl },
			{ '@type': 'ListItem', position: 2, name: 'Coffees', item: `${siteConfig.siteUrl}/products` },
			{ '@type': 'ListItem', position: 3, name: product.name, item: pageUrl },
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Product',
		'@id': pageUrl,
		name: product.name,
		description: product.description,
		url: pageUrl,
		sku: product.sku,
		category: 'Green Coffee',
		countryOfOrigin: {
			'@type': 'Country',
			name: 'India',
		},
		brand: {
			'@type': 'Brand',
			name: 'Gray Cup Enterprises Private Limited',
		},
		...(product.scaScore != null && {
			additionalProperty: [
				{
					'@type': 'PropertyValue',
					name: 'SCA Score',
					value: product.scaScore,
				},
			],
		}),
		offers: {
			'@type': 'AggregateOffer',
			priceCurrency: 'INR',
			lowPrice: product.priceRange.min.toFixed(2),
			highPrice: product.priceRange.max.toFixed(2),
			offerCount: 1,
			availability: 'https://schema.org/InStock',
			itemCondition: 'https://schema.org/NewCondition',
			url: pageUrl,
			seller: {
				'@type': 'Organization',
				name: 'Gray Cup Enterprises Private Limited',
				url: siteConfig.siteUrl,
			},
		},
	},
];
---

<Layout title={title} description={description} schema={schema}>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page">
		<SiteHeader />

		<main id="main-content">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/products">Coffees</a>
				<span aria-hidden="true">/</span>
				<span aria-current="page">{product.name}</span>
			</nav>

			<header class="hero">
				<p class="eyebrow">
					<a href={`/origins/${origin.slug}`}>{origin.name}, {origin.state}</a>
				</p>
				<h1 class="display-title">{product.name}</h1>
				<p class="hero-text">{product.description}</p>
			</header>

			<figure class="hero-image">
				<Image
					src={product.image}
					alt={product.imageAlt}
					loading="eager"
					decoding="async"
					widths={[480, 720, 1040]}
					sizes="(max-width: 900px) 100vw, 46rem"
				/>
			</figure>

			<section class="spec-grid" aria-label="Product specification">
				<div class="spec">
					<p class="spec-label">Variety</p>
					<p class="spec-value">{product.variety}</p>
				</div>
				<div class="spec">
					<p class="spec-label">Process</p>
					<p class="spec-value">{product.process}</p>
				</div>
				<div class="spec">
					<p class="spec-label">Grade</p>
					<p class="spec-value">{product.grade}</p>
				</div>
				<div class="spec">
					<p class="spec-label">Varietal</p>
					<p class="spec-value">{product.varietal}</p>
				</div>
				{
					product.scaScore != null && (
						<div class="spec">
							<p class="spec-label">SCA Score</p>
							<p class="spec-value">{product.scaScore}</p>
						</div>
					)
				}
				<div class="spec">
					<p class="spec-label">Price (FOB India)</p>
					<p class="spec-value">₹{product.priceRange.min}–{product.priceRange.max}{product.priceRange.unit}</p>
				</div>
				<div class="spec">
					<p class="spec-label">Minimum order</p>
					<p class="spec-value">{product.minimumOrder.quantity}{product.minimumOrder.unit}</p>
				</div>
				<div class="spec">
					<p class="spec-label">SKU</p>
					<p class="spec-value">{product.sku}</p>
				</div>
			</section>

			<section class="cta">
				<h2>Interested in {product.name}?</h2>
				<p>
					Get current pricing, sample availability, and shipping to your country at
					<a href="https://bulkgreencoffee.com" target="_blank" rel="noopener noreferrer">bulkgreencoffee.com</a>,
					or email <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
				</p>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.breadcrumb {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		margin: 2rem 0 0;
		font-size: 0.9rem;
		color: var(--muted-foreground);
	}

	.breadcrumb a {
		color: inherit;
		text-decoration: none;
	}

	.breadcrumb a:hover,
	.breadcrumb a:focus-visible {
		text-decoration: underline;
	}

	.hero {
		padding: 2rem 0 3rem;
		max-width: 46rem;
	}

	.eyebrow {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted-foreground);
	}

	.eyebrow a {
		color: inherit;
	}

	.hero-text {
		margin: 1.5rem 0 0;
		font-size: 1.1rem;
		line-height: 1.65;
	}

	.hero-image {
		margin: 2rem 0 0;
		max-width: 32rem;
	}

	.hero-image :global(img) {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 1.25rem;
		box-shadow: var(--shadow-soft);
	}

	.spec-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
		gap: 1.5rem;
		padding: 2.5rem 0;
		border-top: 1px solid var(--border);
	}

	.spec-label {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted-foreground);
	}

	.spec-value {
		margin: 0.4rem 0 0;
		font-size: 1.05rem;
		font-weight: 700;
	}

	.cta {
		padding: 2.5rem 0 1rem;
		border-top: 1px solid var(--border);
	}

	.cta h2 {
		margin: 0;
		font-size: clamp(1.3rem, 1.8vw, 1.6rem);
		font-weight: 800;
		letter-spacing: -0.03em;
	}

	.cta p {
		margin: 0.75rem 0 0;
		font-size: 1.02rem;
		line-height: 1.6;
		color: var(--muted-foreground);
	}

	.cta a {
		color: var(--accent-link);
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
		}
	}
</style>
