---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { siteConfig } from '../../config/site';
import nextpointImage from '../../assets/images/nextpoint.webp';
import nextpointTranscriptsImage from '../../assets/images/nextpoint-transcripts.webp';

const highlights = [
	{ label: 'Client', value: 'Nextpoint' },
	{ label: 'Completed', value: '2026' },
	{ label: 'Role', value: 'Lead UI/UX Designer' },
];

const outcomes = [
	'Clarified the relationship between transcripts, summaries, and open matters.',
	'Made the dashboard easier to scan by separating signals from supporting detail.',
	'Shifted the AI summary area from a passive widget into a more actionable next step.',
];

const caseStudyUrl = new URL('/work/nextpoint', siteConfig.siteUrl).toString();
const caseStudySchema = [
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: 'Home',
				item: siteConfig.siteUrl,
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: 'Work',
				item: new URL('/work', siteConfig.siteUrl).toString(),
			},
			{
				'@type': 'ListItem',
				position: 3,
				name: 'Nextpoint Case Study',
				item: caseStudyUrl,
			},
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'CreativeWork',
		name: 'Nextpoint Case Study',
		headline: 'Sample Nextpoint case study for the Maria Astro portfolio theme',
		description:
			'A sample UI/UX case study page included in the Maria Astro theme for designer portfolios, focused on product design storytelling and structured project presentation.',
		url: caseStudyUrl,
		author: {
			'@type': 'Person',
			name: siteConfig.authorName,
		},
		isPartOf: {
			'@type': 'WebSite',
			name: siteConfig.name,
			url: siteConfig.siteUrl,
		},
		inLanguage: siteConfig.locale,
	},
];
---

<Layout
	title="Nextpoint Case Study | Astro Theme for UI/UX Designer Portfolios"
	description="Sample Nextpoint case study from the Maria Astro theme for UI/UX designer portfolios, built to showcase product design decisions and visual storytelling."
	ogType="article"
	ogImageAlt="Preview of the Nextpoint sample case study page in the Maria Astro theme"
	schema={caseStudySchema}
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="case-page">
		<SiteHeader />

		<main id="main-content">
			<section class="case-hero">
				<p class="eyebrow">
					<a class="breadcrumb-link" href="/work">Case Study</a>
					<span class="breadcrumb-separator" aria-hidden="true">/</span>
					<span>Nextpoint</span>
				</p>
				<h1 class="display-title">Designing a legal dashboard that makes AI summaries feel useful, legible, and trustworthy.</h1>
				<div class="hero-subgrid">
					<p class="hero-text">
						Nextpoint needed a cleaner way to surface transcript activity, AI summaries, and
						recent matters without overwhelming legal teams already working under time pressure.
					</p>
				</div>
			</section>

			<section class="meta-strip" id="overview">
				{highlights.map((item) => (
					<div class="meta-item">
						<p class="meta-label">{item.label}</p>
						<p class="meta-value">{item.value}</p>
					</div>
				))}
			</section>

			<section class="lead-image-section">
				<Image
					class="lead-image"
					src={nextpointImage}
					alt="Nextpoint dashboard showing transcript metrics, AI summary, and recent transcript activity"
					decoding="async"
					widths={[720, 1080, 1440]}
					sizes="(max-width: 78rem) 100vw, 78rem"
				/>
			</section>

			<section class="summary-section">
				<p class="section-kicker">Overview</p>
				<h2>A clearer dashboard for legal teams working with transcripts, summaries, and case activity.</h2>
				<div class="summary-main">
					<p>
						The original experience surfaced the right information, but not with enough
						priority. Users could see metrics, summaries, and recent transcripts, yet still had
						to stop and decide what mattered first.
					</p>
					<p>
						My role was to simplify that decision-making: reshape the hierarchy, tighten the
						interface, and make the AI-assisted parts of the dashboard feel genuinely useful.
					</p>
					<p class="summary-meta">
						<strong>Focus:</strong> Dashboard clarity, hierarchy, AI-assisted workflows
					</p>
					<p class="summary-meta">
						<strong>Scope:</strong> UX audit, UI redesign, visual refinement
					</p>
				</div>
			</section>

			<section class="editorial-section editorial-section-no-divider" id="process">
				<div class="section-rail">
					<p class="section-kicker">What I Did</p>
				</div>
				<div class="story-block">
					<p>
						I started by reviewing the existing dashboard against the product's real use cases:
						what legal teams came here to check, what they needed to do next, and where the
						interface forced unnecessary interpretation.
					</p>
					<p>
						What stood out quickly was that the right information was present, but the page was
						doing very little to guide attention. Metrics, summaries, recent transcripts, and
						longer-term activity all lived together without a strong sense of sequence.
					</p>
					<p>
						So the redesign focused on order. High-level metrics came first, followed by a more
						useful AI summary block, then recent transcript activity, and finally the broader
						activity view. The goal was not to add more. It was to make the existing experience
						easier to read and easier to trust.
					</p>
				</div>
			</section>

			<section class="supporting-image-section">
				<Image
					class="supporting-image"
					src={nextpointTranscriptsImage}
					alt="Nextpoint transcripts view showing transcript summaries and related actions"
					loading="lazy"
					decoding="async"
					widths={[720, 1080, 1440]}
					sizes="(max-width: 78rem) 100vw, 78rem"
				/>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Design Decisions</p>
				</div>
				<div class="story-block">
					<p>
						Legal software becomes visually heavy fast. Once everything looks equally important,
						users stop getting guidance from the interface and start doing that work themselves.
					</p>
					<p>
						The main decision here was to make the page feel calmer without making it feel empty.
						That meant stronger grouping, more breathing room, and clearer contrast between
						primary actions and supporting information.
					</p>
					<p>
						I also treated the AI summary as a useful next step rather than just another dashboard
						module. That shift helped the page feel less like passive reporting and more like
						active support.
					</p>
				</div>
			</section>

			<section class="editorial-section" id="outcome">
				<div class="section-rail">
					<p class="section-kicker">Outcome</p>
				</div>
				<div class="story-block">
					<ul class="outcome-list">
						{outcomes.map((item) => <li>{item}</li>)}
					</ul>
					<p class="closing-text">
						This sample case study is intentionally concise, but the structure is the point: a
						clear problem, a few grounded design decisions, and a visual outcome that feels tied
						to the thinking behind it.
					</p>
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.case-page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.eyebrow,
	.meta-label,
	.section-kicker {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.eyebrow a {
		display: inline-flex;
		align-items: center;
		padding: 0.1rem 0;
		color: var(--foreground);
		text-decoration: none;
		transition: opacity 120ms ease;
	}

	.eyebrow a:hover,
	.eyebrow a:focus-visible {
		opacity: 0.68;
	}

	.case-hero {
		padding: 6rem 0 4rem;
	}

	.eyebrow,
	.meta-label,
	.section-kicker {
		margin: 0;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-bottom: 1.1rem;
		color: var(--muted-foreground);
		font-style: normal;
	}

	.breadcrumb-link {
		font-weight: 600;
	}

	.breadcrumb-separator {
		color: var(--muted-foreground);
	}

	h1,
	h2 {
		margin: 0;
		font-weight: 800;
		letter-spacing: -0.05em;
		color: var(--foreground);
	}

	.hero-subgrid {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.7fr);
		gap: 2rem;
		margin-top: 1.75rem;
	}

	.hero-text,
	.hero-note,
	.summary-main p,
	.summary-meta,
	.story-block p,
	.outcome-list li,
	.closing-text {
		font-size: 1.08rem;
		line-height: 1.7;
	}

	.hero-text,
	.hero-note,
	.summary-main p,
	.summary-meta,
	.story-block p,
	.closing-text {
		margin: 0;
	}

	.hero-note,
	.closing-text {
		color: var(--muted-foreground);
	}

	.meta-strip {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 2rem;
		padding: 1.5rem 0 0.5rem;
		border-top: 1px solid var(--border);
	}

	.meta-item {
		padding-top: 0.75rem;
	}

	.meta-value {
		margin: 0.35rem 0 0;
		font-size: 1.15rem;
		font-weight: 700;
	}

	.lead-image-section {
		padding: 2rem 0 4rem;
	}

	.lead-image {
		width: 100%;
		border: 1px solid var(--border);
		border-radius: 1.5rem;
		box-shadow: var(--shadow-large);
	}

	.supporting-image-section {
		padding: 2rem 0 4rem;
		border-bottom: 1px solid var(--border);
	}

	.supporting-image {
		width: 100%;
		border: 1px solid var(--border);
		border-radius: 1.5rem;
		box-shadow: var(--shadow-large);
	}

	.summary-section {
		padding: 0 0 3rem;
		border-bottom: 1px solid var(--border);
	}

	.summary-section h2 {
		margin-top: 0.75rem;
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 1.04;
	}

	.summary-main {
		display: grid;
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.summary-side p {
		color: var(--muted-foreground);
	}

	.summary-side strong {
		color: var(--foreground);
	}

	.summary-meta {
		color: var(--muted-foreground);
	}

	.summary-meta strong {
		color: var(--foreground);
	}

	.editorial-section {
		display: grid;
		grid-template-columns: 16rem minmax(0, 1fr);
		gap: 2rem;
		padding: 2.5rem 0;
		border-bottom: 1px solid var(--border);
	}

	#outcome {
		border-bottom: 0;
	}

	.editorial-section-no-divider {
		border-bottom: 0;
		padding-bottom: 0;
	}

	.section-rail {
		align-self: start;
	}

	.story-block {
		display: grid;
		gap: 1rem;
		max-width: 52rem;
		margin-top: 0;
	}

	.outcome-list {
		margin: 0;
		padding-left: 1.25rem;
		list-style: disc;
	}

	.outcome-list li::marker {
		color: var(--foreground);
	}

	.closing-text {
		margin-top: 1.5rem;
	}

	@media (max-width: 980px) {
		.hero-subgrid,
		.meta-strip {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.case-page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.editorial-section {
			grid-template-columns: 1fr;
		}

		.case-hero {
			padding: 4rem 0 3rem;
		}

		.hero-text,
		.hero-note,
		.summary-main p,
		.summary-meta,
		.story-block p,
		.outcome-list li,
		.closing-text {
			font-size: 1.05rem;
		}
	}
</style>
